# ── ENEM data ─────────────────────────────────────────────────────────────────
# Path to microdata CSV (https://www.gov.br/inep/pt-br/acesso-a-informacao/dados-abertos/microdados/enem)
# Leave empty to use built-in 60k-row synthetic sample.
ENEM_DATA_PATH=

# Max rows to load from the CSV (0 = all; full dataset ≈ 3M rows)
ENEM_SAMPLE_SIZE=200000

# ── AI narrative (optional) ────────────────────────────────────────────────────
# Get a free key at https://console.mistral.ai
# Without a key the app uses pre-written fallback insights.
MISTRAL_API_KEY=
