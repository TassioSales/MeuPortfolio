# ── BasedosDados / BigQuery ─────────────────────────────────────────────────
# Para usar microdados ANP por posto (muito mais ricos que os CSVs agregados):
#
# 1. Crie um projeto no Google Cloud Console: https://console.cloud.google.com
# 2. Ative a BigQuery API no projeto
# 3. Autentique: gcloud auth application-default login
# 4. Preencha o billing project abaixo:
#
GCP_BILLING_PROJECT=seu-projeto-gcp-aqui

# Anos a consultar (reduz custo — query por ano cobra ~50MB por coluna por ano)
GCP_YEARS=2023,2024,2025

# Limite de linhas por query (default: 5.000.000)
GCP_LIMIT=5000000

# ── Alternativa: service account ────────────────────────────────────────────
# Aponte para um arquivo JSON de service account se nao usar gcloud auth:
# GOOGLE_APPLICATION_CREDENTIALS=C:/caminho/para/chave.json
