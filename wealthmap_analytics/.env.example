# WealthMap Analytics PRO — Variáveis de Ambiente

# Chave da API Mistral (obrigatória para o assistente WealthMap AI)
MISTRAL_API_KEY=sua_chave_aqui

# Modelo Mistral a usar (padrão: mistral-small-latest)
MISTRAL_MODEL=mistral-small-latest

# URL da API do backend (usada pelo frontend Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
