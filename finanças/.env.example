# ─── Django core ─────────────────────────────────────────────────────────────
# Gere uma nova chave para produção:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=sua_chave_secreta_aqui

DEBUG=True

# Vírgula separada. Use * apenas para acesso na rede local. Restrinja em produção.
ALLOWED_HOSTS=*

# ─── Banco de Dados (PostgreSQL) ──────────────────────────────────────────────
# Deixe em branco para usar SQLite automaticamente.
# DB_NAME=finance_db
# DB_USER=postgres
# DB_PASSWORD=sua_senha
# DB_HOST=localhost
# DB_PORT=5432

# ─── Banco de Dados (SQLite personalizado) ────────────────────────────────────
# SQLITE_DB_PATH=/caminho/para/db.sqlite3
